# =============================================================================
# Simo's Agentic Coding Boilerplate — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# Lines marked [REQUIRED] must be set before the app will start.
# Lines marked [OPTIONAL] enable extra features.
# =============================================================================


# -----------------------------------------------------------------------------
# DATABASE
# -----------------------------------------------------------------------------
# [REQUIRED] Your PostgreSQL connection string.
#
# For LOCAL DEVELOPMENT (using Docker):
#   1. Run: docker compose up -d
#   2. Use the URL below as-is:
POSTGRES_URL="postgresql://dev_user:dev_password@localhost:5432/app_dev"
#
# For PRODUCTION (using Neon — https://neon.tech):
#   1. Create a free Neon project
#   2. Copy the connection string from your Neon dashboard
#   3. Replace the URL above with your Neon connection string


# -----------------------------------------------------------------------------
# AUTHENTICATION
# -----------------------------------------------------------------------------
# [REQUIRED] A random secret used to sign auth tokens.
# Generate one: openssl rand -base64 32
BETTER_AUTH_SECRET="CHANGE-ME-generate-a-random-32-char-string"

# [OPTIONAL] Google OAuth — enables "Sign in with Google"
# Get these from: https://console.cloud.google.com/apis/credentials
# Redirect URI: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""


# -----------------------------------------------------------------------------
# AI INTEGRATION
# -----------------------------------------------------------------------------
# [OPTIONAL] OpenRouter — gives you access to 100+ AI models (GPT, Claude, etc.)
# Get your key: https://openrouter.ai/settings/keys
# Browse models: https://openrouter.ai/models
OPENROUTER_API_KEY=""
OPENROUTER_MODEL="openai/gpt-4.1-mini"


# -----------------------------------------------------------------------------
# FILE STORAGE
# -----------------------------------------------------------------------------
# [OPTIONAL] Vercel Blob — cloud file storage for production
# Leave empty to use local storage (public/uploads/) during development.
# For production: Vercel Dashboard → Storage → Create Blob Store
BLOB_READ_WRITE_TOKEN=""


# -----------------------------------------------------------------------------
# APP
# -----------------------------------------------------------------------------
# [REQUIRED] The URL where your app runs.
# Change this to your real domain when deploying.
NEXT_PUBLIC_APP_URL="http://localhost:3000"
